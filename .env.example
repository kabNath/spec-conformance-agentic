# Clerk (auth + Organizations = tenants)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# PostgreSQL (Prisma) — relational store
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conformance

# Qdrant — vector store (fallback retrieval)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Neo4j — clause cross-reference graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# OpenRouter — LLM gateway (agent calls)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Embeddings (OpenRouter-compatible or OpenAI) for Qdrant vectors
EMBEDDINGS_MODEL=openai/text-embedding-3-small

# Cloudinary — raw uploaded document storage
CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud>

# Vidimus eval sidecar (calibrated confidence + signed attestation)
VIDIMUS_URL=http://localhost:4319
